# --- Prisma / Supabase (Vercel Production 환경 변수에도 동일하게 설정) ---
#
# 권장: Session pooler (IPv4 환경에서 안정적)
# Supabase → Project Settings → Database → Connection string → Session mode / Pooler
# 예시 (비밀번호·호스트는 본인 프로젝트 값으로 교체):
# postgresql://postgres.xxxxx:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
#
# 비밀번호에 @ # % 등 특수문자가 있으면 URL 인코딩 필수입니다.
#
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

# (선택) 앱에서 Supabase 클라이언트를 쓸 때만
# SUPABASE_URL="https://xxxxx.supabase.co"
# SUPABASE_ANON_KEY="your_anon_key"
